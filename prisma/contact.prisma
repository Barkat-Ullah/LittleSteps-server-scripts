model Contact {
    id        String        @id @default(auto()) @map("_id") @db.ObjectId
    userId    String?       @db.ObjectId
    name      String
    email     String
    subject   String
    message   String
    status    ContactStatus @default(Pending)
    isDeleted Boolean       @default(false)
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
    //relation
    user      User?         @relation(fields: [userId], references: [id])

    @@index([userId])
    @@index([status, isDeleted])
    @@map("contact")
}

enum ContactStatus {
    Pending
    Inprogress
    Solved
}

model Inspire {
    id        String            @id @default(auto()) @map("_id") @db.ObjectId
    text      String
    date      DateTime?
    status    EnumInspireStatus
    type      EnumInspireType
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt

    @@map("inspire")
}

enum EnumInspireStatus {
    Sent
    Manual
    Scheduled
}

enum EnumInspireType {
    Automatic
    Schedule
}