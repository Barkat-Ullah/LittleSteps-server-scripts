{
  "name": "little-step-server",
  "type": "module",
  "prisma": {
    "schema": "./prisma"
  },
  "scripts": {
    "start": "node ./dist/server.js",
    "dev": "tsx watch ./src/server.ts",
    "pm": "npx prisma migrate dev ",
    "pg": "npx prisma generate",
    "generate": "ts-node src/generate-module.js",
    "generate-folder": "ts-node src/generate-module-optimized.js",
    "build": "npx prisma generate && tsc",
    "postinstall": "prisma generate",
    "lint:check": "eslint --ignore-path .eslintignore --ext .js,.ts .",
    "lint:fix": "eslint . --fix",
    "prettier:check": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "prettier:fix": "prettier --write .",
    "lint-prettier": "yarn lint:check && yarn prettier:check",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@bull-board/api": "^6.16.4",
    "@bull-board/express": "^6.16.4",
    "@bull-board/ui": "^6.16.4",
    "@prisma/client": "^6.19.1",
    "@sendgrid/mail": "^8.1.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.9",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.16.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "http-status": "^2.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.18.0",
    "sharp": "^0.34.5",
    "stripe": "^18.5.0",
    "twilio": "^5.12.0",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "tsx": "^4.22.4"
  },
  "overrides": {
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@prisma/internals": "^6.19.3",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.3.3"
  }
}
